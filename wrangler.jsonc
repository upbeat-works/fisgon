{
  "name": "fisgon-agent",
  "main": "src/agent/worker.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      { "name": "Fisgon", "class_name": "FisgonAgent" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["FisgonAgent"] }
  ],
  "browser": {
    "binding": "BROWSER"
  },
  "vars": {
    "ACCOUNT_ID": "761909453e0f7ab0054e0466947f3ad0",
    "AI_GATEWAY": "fisgon"
  }
}
